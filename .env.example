# Copy this file to .env and fill in the values before running docker-compose up

# A long random secret for signing JWTs — generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# The public URL users will access (used for CORS)
FRONTEND_URL=https://your-domain.com

# Cloudflare Tunnel token — get this from the Cloudflare Zero Trust dashboard
# after creating a tunnel and pointing it to http://nginx:80
TUNNEL_TOKEN=your_cloudflare_tunnel_token
